[Unit]
Description=Workbench news headline Simplified-Chinese translation (off request path, no-AI rule (e): translate only)
Documentation=https://github.com/tripplemay/trade/blob/main/docs/specs/B054-ai-text-localization-spec.md
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=deploy
Group=deploy
WorkingDirectory=/srv/workbench/current/backend

# Secrets (WORKBENCH_DB_URL, AIGC_GATEWAY_API_KEY, ...) live in
# /etc/workbench/workbench.env (chmod 600 root:deploy). Never committed.
EnvironmentFile=/etc/workbench/workbench.env

# B054 F-news (boundary (r) + §12.10.2): this timer runs the GENERATIVE news
# headline translation precompute — it calls the LLM gateway (advise, no-AI
# boundary rule (e): translate only) OFF the request path and writes the
# pre-computed news.title_zh column. Mirrors the B043 risk-explanation timer
# (generative, off-request-path, CI-safety-gated, cost-guarded). ExecStart
# invokes the translation CLI and nothing else — it never runs broker /
# order-ticket / execution / fills / reconcile / recommendation-scoring code.
# tests/safety/test_market_scheduler_scope.py greps this ExecStart line and
# scans the news_translation package to enforce that.
ExecStart=/opt/workbench/.venv/bin/python -m workbench_api.news_translation.cli

# Standard hardening (mirrors workbench-recommendations.service): network +
# DB + /tmp only; no write access outside the persistent data + log roots.
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/workbench /var/log/workbench /tmp

# No [Install] section — this oneshot is pulled by
# workbench-news-translate.timer, never enabled / started directly.
