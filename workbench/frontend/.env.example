# Workbench frontend environment template.
# Copy to `.env.local` and fill secrets locally; production values live on
# the VM under /opt/<app>/workbench/frontend/.env.production (untracked).

# --- B026 Synthetic data banner ----------------------------------------
# When the workbench is running on Layer 0 fixture data (no real market
# data), a persistent yellow banner is rendered at the top of every
# (protected) page warning that figures are research-only / synthetic.
#
# Default (unset or `true`): banner visible. Local dev runs against the
# B025 synthetic fixture by default, so dev keeps `=true`.
#
# B030 F003 (2026-05-27): production `.env.production` ships `=false`
# because milestone A Layer 0→1 is complete — the unified
# (SEC EDGAR + Tiingo) backfill is wired and the workbench renders
# real historical data. The component code in
# `src/components/SyntheticDataBanner.tsx` is preserved so a future
# downgrade back to Layer 0 can flip this flag and re-enable the
# banner without touching component code (永久边界 (k):
# Layer 状态不可逆向滑落 — flip must be a deliberate spec decision).
NEXT_PUBLIC_SYNTHETIC_DATA_BANNER=true
