# Workbench frontend environment template.
# Copy to `.env.local` and fill secrets locally; production values live on
# the VM under /opt/<app>/workbench/frontend/.env.production (untracked).

# --- B026 Synthetic data banner ----------------------------------------
# When the workbench is running on Layer 0 fixture data (no real market
# data), a persistent yellow banner is rendered at the top of every
# (protected) page warning that figures are research-only / synthetic.
#
# Default (unset or `true`): banner visible.
# `false`: banner hidden. Flip to `false` on the VM only after the Phase 1
# Real Data milestone (B030) is signed off and every sleeve uses real data.
NEXT_PUBLIC_SYNTHETIC_DATA_BANNER=true
