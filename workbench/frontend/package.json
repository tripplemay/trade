{
  "name": "workbench-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Workbench frontend (B020 dev infrastructure skeleton).",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "generate-types": "bash scripts/generate-types.sh",
    "format": "prettier --write \"{src,tests,scripts}/**/*.{ts,tsx,js,mjs,css,md,json}\"",
    "format:check": "prettier --check \"{src,tests,scripts}/**/*.{ts,tsx,js,mjs,css,md,json}\""
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "ag-grid-community": "^35.3.0",
    "ag-grid-react": "^35.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "lightweight-charts": "^5.2.0",
    "lucide-react": "^1.16.0",
    "next": "14.2.33",
    "next-auth": "^5.0.0-beta.25",
    "next-themes": "^0.4.6",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-resizable-panels": "^4.11.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@playwright/test": "1.48.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "20.16.11",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.33",
    "happy-dom": "^20.9.0",
    "openapi-typescript": "7.4.2",
    "postcss": "8.4.47",
    "prettier": "3.3.3",
    "prettier-plugin-tailwindcss": "0.6.8",
    "start-server-and-test": "2.0.8",
    "tailwindcss": "3.4.14",
    "typescript": "5.6.3",
    "vitest": "2.1.3"
  }
}
