# Workbench backend environment template.
# Copy to `.env` (gitignored) for local dev; production uses systemd
# EnvironmentFile=/etc/workbench/workbench.env which the deploy workflow
# rewrites from GitHub repo secrets.

# --- B021 OAuth / single-user allowlist -------------------------------------
NEXTAUTH_SECRET=
ALLOWED_USER_EMAIL=

# --- B022 paths -------------------------------------------------------------
WORKBENCH_DB_URL=sqlite:///./workbench-dev.db
WORKBENCH_BACKUP_LOG=/var/log/workbench/backup.log
WORKBENCH_LOG_DIR=/var/log/workbench
WORKBENCH_REPORTS_DIR=docs/test-reports
WORKBENCH_RUNS_DIR=docs/runs

# --- B021 F006 observability (optional) -------------------------------------
SENTRY_DSN=

# --- B027 Real Data ---------------------------------------------------------
# Tiingo Starter $10/month API key for real EOD market data ingest.
# Obtain at https://api.tiingo.com/account/api/token (single-user account).
# Production VM gets this via systemd EnvironmentFile, populated by the
# GitHub Actions deploy workflow from the TIINGO_API_KEY repo secret.
# Backend-only secret — never expose in the frontend bundle or any log line.
TIINGO_API_KEY=

# --- B029 SEC EDGAR fundamentals -------------------------------------------
# Contact email required by SEC EDGAR's fair-access User-Agent policy
# (永久边界 (h); https://www.sec.gov/os/accessing-edgar-data). SEC will
# ban the source IP for 30 days without a valid contact in the UA header.
# Use a generic research-only mailbox; never inline into the frontend bundle.
# Production VM gets this via systemd EnvironmentFile, populated from the
# SEC_EDGAR_CONTACT_EMAIL GitHub repo secret.
SEC_EDGAR_CONTACT_EMAIL=research@example.com

# --- B031 LLM gateway (Stream 3.A / Phase 2 starting infra) -----------------
# Single backend-only API key for the aigc-gateway HTTP REST surface
# (https://aigc-gateway.example.com/dashboard). Provider-specific keys
# (Anthropic / OpenAI / Gemini / Cohere) live INSIDE aigc-gateway; the
# workbench backend only carries this one key. Generate via
# `mcp__aigc-gateway__create_api_key` or the aigc-gateway dashboard.
# Production VM gets this via systemd EnvironmentFile, populated from
# the AIGC_GATEWAY_API_KEY GitHub repo secret by .github/workflows/
# bootstrap-env.yml (v0.9.30 §12.9 four-place wiring). Permanent
# boundary (l): business code routes by task name through
# workbench_api/llm/routing.py — model names never appear in callers.
# Permanent boundary (m): monthly cap ¥1500 enforced by F002 cost guard.
AIGC_GATEWAY_API_KEY=

# --- B035 Market Context (Stream 2.C / Phase 2) -----------------------------
# FRED (Federal Reserve Economic Data) API key for the macro market-context
# series (10y DGS10 / VIX VIXCLS / CPI CPIAUCSL). Free key from
# https://fred.stlouisfed.org/docs/api/api_key.html. Backend-only secret —
# never inline into the frontend bundle. Production VM gets this via systemd
# EnvironmentFile, populated from the FRED_API_KEY GitHub repo secret by
# .github/workflows/bootstrap-env.yml (v0.9.30 §12.9 four-place wiring).
FRED_API_KEY=
# Alpha Vantage API key for the index market-context series (SPY / QQQ / UUP
# via GLOBAL_QUOTE). Free key from https://www.alphavantage.co/support/#api-key
# (note: 25 requests/day free-tier cap — the daily fetch makes only 3).
# Backend-only secret. Production VM gets this via systemd EnvironmentFile,
# populated from the ALPHAVANTAGE_API_KEY GitHub repo secret.
ALPHAVANTAGE_API_KEY=
