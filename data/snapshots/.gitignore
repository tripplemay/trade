# B028 F002 — snapshot data is generated by scripts/backfill_prices.py
# (B028 prices) + scripts/backfill_fundamentals.py (B029 fundamentals)
# and is too large to track in git. The README + this gitignore stay
# committed so the directory layout survives a fresh clone.
#
# Re-create snapshots with:
#   python scripts/backfill_prices.py --from 2014-01-01 --to <today> --universe master
#   SEC_EDGAR_CONTACT_EMAIL=<your-email> \
#     python scripts/backfill_fundamentals.py --from 2014-01-01 --to <today> --universe us_quality
#
# Everything except markdown / schema samples / .gitignore is ignored.

# Generated payloads.
*.csv
*.parquet
*.feather
*.arrow
# B029 — SEC raw companyfacts + per-CIK parsed_ratios + metadata are
# large JSON files; same "regenerate, don't commit" semantics as the
# CSV payloads.
*.json

# But keep documentation + schema samples + ignore file itself.
!README.md
!*.schema.json
!.gitignore
