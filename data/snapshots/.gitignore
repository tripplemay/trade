# B028 F002 — snapshot data is generated by scripts/backfill_prices.py
# and is too large to track in git. The README + this gitignore stay
# committed so the directory layout survives a fresh clone.
#
# Re-create snapshots with:
#   python scripts/backfill_prices.py --from 2014-01-01 --to <today> --universe master
#
# Everything except markdown / json / shape samples is ignored.

# Generated CSV / parquet payloads.
*.csv
*.parquet
*.feather
*.arrow

# But keep documentation + schema samples + ignore file itself.
!README.md
!*.schema.json
!.gitignore
