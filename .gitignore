# Harness agent local identity（本机身份，不入 git）
.agent-id

# Secrets and local environment
.env
.env.*
!.env.example
# B030 F003 — frontend production env (NEXT_PUBLIC_* build-time flags only;
# no secrets here). Tracked so the banner-off setting ships with the repo
# rather than living only in a CI workflow inline env block.
!workbench/frontend/.env.production
*.key
*.pem

# Python / notebooks
.venv/
__pycache__/
.pytest_cache/
.ipynb_checkpoints/

# Market data and local databases
data/*
!data/.gitkeep
!data/fixtures/
!data/snapshots/
*.parquet
*.csv
*.db
*.sqlite
*.sqlite3
logs/

# Synthetic fixtures committed for offline CI (B025 etc.)
!data/fixtures/**

# B028 F002 — snapshot layout: README + per-dir gitignore committed,
# generated CSV / parquet payloads remain ignored via
# data/snapshots/.gitignore (the dir's own ignore file).
!data/snapshots/README.md

# B032 F001 — safety eval red-team dataset is source-of-truth for the
# AI safety eval CI gate (permanent boundary (n)(o)); must ship in
# the repo so deploys can re-run the gate.
!data/safety-evals/
!data/safety-evals/**
!data/snapshots/.gitignore

# OS / editor
.DS_Store
*.swp
*.swo

# Local editor / SQLite transient artifacts
.obsidian/
*.db-shm
*.db-wal
