# Harness agent local identity（本机身份，不入 git）
.agent-id

# Secrets and local environment
.env
.env.*
!.env.example
*.key
*.pem

# Python / notebooks
.venv/
__pycache__/
.pytest_cache/
.ipynb_checkpoints/

# Market data and local databases
data/*
!data/.gitkeep
!data/fixtures/
*.parquet
*.csv
*.db
*.sqlite
*.sqlite3
logs/

# Synthetic fixtures committed for offline CI (B025 etc.)
!data/fixtures/**

# OS / editor
.DS_Store
*.swp
*.swo
